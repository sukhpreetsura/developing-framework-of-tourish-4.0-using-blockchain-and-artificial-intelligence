# Simple Blockchain for Tourist Data Security

import hashlib
import datetime

class Block:

    def __init__(self, index, data, previous_hash):
        self.index = index
        self.timestamp = str(datetime.datetime.now())
        self.data = data
        self.previous_hash = previous_hash
        self.hash = self.create_hash()

    def create_hash(self):
        block_data = (
            str(self.index) +
            self.timestamp +
            str(self.data) +
            self.previous_hash
        )

        return hashlib.sha256(block_data.encode()).hexdigest()

class Blockchain:

    def __init__(self):
        self.chain = [self.create_genesis_block()]

    def create_genesis_block(self):
        return Block(0, "Genesis Block", "0")

    def get_last_block(self):
        return self.chain[-1]

    def add_block(self, data):

        previous_block = self.get_last_block()

        new_block = Block(
            len(self.chain),
            data,
            previous_block.hash
        )

        self.chain.append(new_block)

# Create blockchain
tourism_chain = Blockchain()

# Add tourist data
tourism_chain.add_block({
    "Tourist Name": "Sukhpreet",
    "Destination": "Manali",
    "Booking Amount": 15000
})

tourism_chain.add_block({
    "Tourist Name": "Rahul",
    "Destination": "Shimla",
    "Booking Amount": 12000
})

# Display blockchain
for block in tourism_chain.chain:

    print("\nBlock Index:", block.index)
    print("Timestamp:", block.timestamp)
    print("Data:", block.data)
    print("Hash:", block.hash)
    print("Previous Hash:", block.previous_hash)
